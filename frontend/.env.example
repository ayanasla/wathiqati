# Frontend Environment Configuration

# API Server URL (set based on environment)
REACT_APP_API_URL=http://localhost:5002

# Environment mode (development, staging, production)
REACT_APP_ENV=development

# Enable debug mode (shows more verbose logs)
REACT_APP_DEBUG=false

# Feature flags (enable/disable features)
REACT_APP_FEATURE_PDF=true
REACT_APP_FEATURE_NOTIFICATIONS=true
REACT_APP_FEATURE_ADVANCED_FILTERS=true
REACT_APP_FEATURE_BULK_ACTIONS=false

# Toast notification position (top-right, top-left, bottom-right, bottom-left)
REACT_APP_TOAST_POSITION=top-right

# Max file upload size in MB
REACT_APP_MAX_FILE_SIZE=10

# Request timeout in milliseconds
REACT_APP_REQUEST_TIMEOUT=30000

# Pagination default limit
REACT_APP_DEFAULT_PAGE_LIMIT=20

# Optional: Sentry error tracking
REACT_APP_SENTRY_DSN=
