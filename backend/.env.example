# ================================================
# WATHIQATI BACKEND - ENVIRONMENT CONFIGURATION
# ================================================
# Copy this file to .env and update with your settings

# ================================================
# APPLICATION
# ================================================
NODE_ENV=development
PORT=3001
APP_NAME=Wathiqati
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ================================================
# DATABASE - MySQL Configuration
# ================================================
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wathiqati_db
DB_TIMEZONE=+00:00
DB_LOGGING=false

# ================================================
# DATABASE - SQLite Configuration (for development)
# ================================================
# Uncomment to use SQLite instead of MySQL
# DB_DIALECT=sqlite
# DB_STORAGE=./database.sqlite

# ================================================
# DATABASE - PostgreSQL Configuration
# ================================================
# Uncomment to use PostgreSQL instead of MySQL
# DB_DIALECT=postgres
# DB_PORT=5432
# DB_SSL=false

# ================================================
# AUTHENTICATION
# ================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# ================================================
# FILE UPLOAD
# ================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png

# ================================================
# EMAIL CONFIGURATION (Optional)
# ================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@wathiqati.com
SMTP_FROM_NAME=Wathiqati

# ================================================
# PAGINATION
# ================================================
DEFAULT_PAGE_LIMIT=10
DEFAULT_PAGE=1

# ================================================
# CORS
# ================================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ================================================
# LOGGING
# ================================================
LOG_LEVEL=debug
LOG_DIR=./logs

# ================================================
# SECURITY
# ================================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ================================================
# FEATURE FLAGS
# ================================================
ENABLE_API_DOCS=true
ENABLE_SAMPLE_DATA=false
